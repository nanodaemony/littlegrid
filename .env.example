# ============================================================
# LittleGrid Docker 部署环境变量配置
# 复制此文件为 .env 并填入真实值
# ============================================================

# ============================================================
# MySQL 数据库配置
# ============================================================
# MySQL root 密码 (请修改为强密码)
DB_ROOT_PASSWORD=your_mysql_password_here

# 数据库名称
DB_NAME=eladmin

# 数据库端口映射 (宿主机端口:容器端口)
DB_PORT=3306

# ============================================================
# Redis 配置
# ============================================================
# Redis 密码 (请修改为强密码)
REDIS_PWD=your_redis_password_here

# Redis 端口映射 (宿主机端口:容器端口)
REDIS_PORT=6379

# ============================================================
# 服务端口配置
# ============================================================
# 后端服务端口
BACKEND_PORT=8000

# 前端服务端口
FRONTEND_PORT=8001

# ============================================================
# Admin 后台配置
# ============================================================
# Admin 登录用户名
ADMIN_USERNAME=admin

# Admin 登录密码 (请修改为强密码)
ADMIN_PASSWORD=admin123